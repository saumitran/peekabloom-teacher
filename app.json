{
  "expo": {
    "name": "Peekabloom",
    "slug": "peekabloom-teacher",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "peekabloom",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.peekabloom.teacher",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Peekabloom records audio to capture voice observations about children.",
        "NSSpeechRecognitionUsageDescription": "Peekabloom uses speech recognition to transcribe observations in real time."
      }
    },
    "android": {
      "package": "com.peekabloom.teacher",
      "adaptiveIcon": {
        "backgroundColor": "#1A1A2E",
        "foregroundImage": "./assets/images/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Peekabloom records audio to capture voice observations about children."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Peekabloom records audio to capture voice observations about children.",
          "speechRecognitionPermission": "Peekabloom uses speech recognition to transcribe observations in real time."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
